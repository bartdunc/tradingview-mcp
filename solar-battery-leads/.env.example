# Server
PORT=3300

# Admin dashboard access token (sent as "Authorization: Bearer <token>")
ADMIN_TOKEN=change-me

# Score at/above this value triggers a "hot lead" email notification
HOT_LEAD_THRESHOLD=75

# Optional SMTP config for hot-lead email notifications.
# If SMTP_HOST is unset, notifications are just logged to the console.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
NOTIFY_FROM=leads@example.com
NOTIFY_TO=sales@example.com
