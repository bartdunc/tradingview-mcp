rd16_new=rd16 and not rd16[1]  rd17_new=rd17 and not rd17[1]  rd18_new=rd18 and not rd18[1]
rd19_new=rd19 and not rd19[1]  rd20_new=rd20 and not rd20[1]

dq = '"'
f_short_msg(name, price_s, dp, fl, tb, score) =>
    "{" + dq + "content" + dq + ":" + dq +
    "🔴 **SHORT READY: " + name + "**\\n" +
    "Price: $" + price_s + "\\n" +
    "Prior Drop: -" + str.tostring(dp,"#.0") + "%\\n" +
    "Bounce Range: " + str.tostring(fl,"#.0") + "%\\n" +
    "To Breakdown: " + str.tostring(tb,"#.1") + "%\\n" +
    "Market Regime Score: " + str.tostring(score) + "/10\\n" +
    "▶ Short on breakdown below dead-cat-bounce low\\n" +
    "📊 Bear Flag Scanner [TraderXO]" + dq + "}"

if rd01_new
    alert(f_short_msg(f_ticker(sym01),f_price_fmt(c01),dp01,fl01,tb01,bear_score),alert.freq_once_per_bar)
