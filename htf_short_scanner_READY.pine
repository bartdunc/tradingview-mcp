// ─── ALERT ENGINE ──────────────────────────────────────────────────────────
rd01_new=rd01 and not rd01[1]  rd02_new=rd02 and not rd02[1]  rd03_new=rd03 and not rd03[1]
rd04_new=rd04 and not rd04[1]  rd05_new=rd05 and not rd05[1]  rd06_new=rd06 and not rd06[1]
rd07_new=rd07 and not rd07[1]  rd08_new=rd08 and not rd08[1]  rd09_new=rd09 and not rd09[1]
