//@version=6
indicator("TraderXO — HTF Short Scanner", overlay=false, max_boxes_count=0, max_lines_count=0, max_labels_count=0)

// ─── PARAMETERS ────────────────────────────────────────────────────────────
drop_lookback = input.int(25,    "Prior Drop Lookback (bars)",   group="Setup Criteria", minval=10, maxval=60)
drop_min_pct  = input.float(25.0,"Min Prior Drop %",             group="Setup Criteria", minval=10, maxval=80, step=1.0)
flag_bars     = input.int(12,    "Dead Cat Bounce Bars",         group="Setup Criteria", minval=5,  maxval=30)
flag_max_pct  = input.float(18.0,"Max Bounce Range %",           group="Setup Criteria", minval=5,  maxval=40, step=0.5)
vol_dry_mult  = input.float(0.9, "Vol Dry-Up Multiplier",        group="Setup Criteria", minval=0.3,maxval=1.5, step=0.1)
near_bd_pct   = input.float(5.0, "Near Breakdown Threshold %",   group="Setup Criteria", minval=1,  maxval=15, step=0.5)

// ─── SYMBOLS ───────────────────────────────────────────────────────────────
sym01 = input.symbol("BINANCE:ETHUSDT",   "Asset 01", group="Assets")
sym02 = input.symbol("BINANCE:SOLUSDT",   "Asset 02", group="Assets")
sym03 = input.symbol("BINANCE:BNBUSDT",   "Asset 03", group="Assets")
sym04 = input.symbol("BINANCE:AVAXUSDT",  "Asset 04", group="Assets")
sym05 = input.symbol("BINANCE:LINKUSDT",  "Asset 05", group="Assets")
sym06 = input.symbol("BINANCE:DOTUSDT",   "Asset 06", group="Assets")
sym07 = input.symbol("BINANCE:ADAUSDT",   "Asset 07", group="Assets")
sym08 = input.symbol("BINANCE:ATOMUSDT",  "Asset 08", group="Assets")
sym09 = input.symbol("BINANCE:NEARUSDT",  "Asset 09", group="Assets")
sym10 = input.symbol("BINANCE:APTUSDT",   "Asset 10", group="Assets")
sym11 = input.symbol("BINANCE:ARBUSDT",   "Asset 11", group="Assets")
sym12 = input.symbol("BINANCE:OPUSDT",    "Asset 12", group="Assets")
sym13 = input.symbol("BINANCE:SUIUSDT",   "Asset 13", group="Assets")
sym14 = input.symbol("BINANCE:INJUSDT",   "Asset 14", group="Assets")
sym15 = input.symbol("BINANCE:LDOUSDT",   "Asset 15", group="Assets")
sym16 = input.symbol("BINANCE:AAVEUSDT",  "Asset 16", group="Assets")
sym17 = input.symbol("BINANCE:UNIUSDT",   "Asset 17", group="Assets")
sym18 = input.symbol("BINANCE:SANDUSDT",  "Asset 18", group="Assets")
sym19 = input.symbol("BINANCE:GALAUSDT",  "Asset 19", group="Assets")
sym20 = input.symbol("BINANCE:POLUSDT",   "Asset 20", group="Assets")

// ─── MARKET REGIME ENGINE (BTC Weekly) ────────────────────────────────────
f_btc_regime() =>
    ema50_w   = ta.ema(close, 50)
    ema200_w  = ta.ema(close, 200)
    [_, _, h] = ta.macd(close, 12, 26, 9)
    rsi14_w   = ta.rsi(close, 14)
    hi52      = ta.highest(close, 52)
    dd_from_ath = hi52 > 0 ? (hi52 - close) / hi52 * 100 : 0.0
    // Bear score: each condition adds points
    s1 = close < ema50_w  ? 2 : 0   // below weekly EMA50
    s2 = close < ema200_w ? 3 : 0   // below weekly EMA200 (heavy weight)
    s3 = h < 0            ? 1 : 0   // weekly MACD histogram negative
    s4 = rsi14_w < 50     ? 1 : 0   // weekly RSI below midline
    s5 = dd_from_ath > 30 ? 2 : dd_from_ath > 20 ? 1 : 0  // drawdown from ATH
    s6 = ema50_w < ema200_w ? 1 : 0  // weekly death cross
    bear_score = s1 + s2 + s3 + s4 + s5 + s6
    [close, ema50_w, ema200_w, h, rsi14_w, dd_from_ath, bear_score]

[btc_w_close, btc_ema50_w, btc_ema200_w, btc_hist_w, btc_rsi_w, btc_dd, bear_score] =
     request.security("BINANCE:BTCUSDT", "W", f_btc_regime())

regime_bear   = bear_score >= 6
regime_trans  = bear_score >= 3 and bear_score < 6
regime_bull   = bear_score < 3

// ─── BEAR FLAG DETECTION FUNCTION ─────────────────────────────────────────
f_bear_htf() =>
    vol_ma20  = ta.sma(volume, 20)
    ema200    = ta.ema(close, 200)
    below_200 = close < ema200

    // Prior sharp drop: how far did price fall from the recent high?
    recent_high    = ta.highest(high, drop_lookback)[1]
    prior_drop_pct = recent_high > 0 ? (recent_high - close[1]) / recent_high * 100 : 0.0
    has_prior_drop = prior_drop_pct >= drop_min_pct

    // Dead cat bounce: tight consolidation after the drop (all [1] to exclude current bar)
    flag_high_raw = ta.highest(high, flag_bars)[1]
    flag_low_raw  = ta.lowest(low,   flag_bars)[1]
    flag_mid      = (flag_high_raw + flag_low_raw) / 2.0
    fl_rng        = flag_mid > 0 ? (flag_high_raw - flag_low_raw) / flag_mid * 100 : 999.0
    bounce_tight  = fl_rng <= flag_max_pct

    // Volume dry-up during bounce (no conviction in the relief rally)
    vol_flag_avg = ta.sma(volume, flag_bars)[1]
    dryup        = vol_flag_avg < vol_ma20 * vol_dry_mult

    // Distance to breakdown: how close is price to the flag LOW (support)?
    to_bd         = flag_low_raw > 0 ? (close - flag_low_raw) / close * 100 : 999.0
    near_breakdown = to_bd >= 0.0 and to_bd <= near_bd_pct

    // Status tiers
    ready    = below_200 and has_prior_drop and bounce_tight and dryup and near_breakdown
    forming  = below_200 and has_prior_drop and bounce_tight and dryup and not near_breakdown
    watching = below_200 and has_prior_drop and not bounce_tight

    [close, prior_drop_pct, fl_rng, dryup, to_bd, ready, forming, watching]

// ─── FETCH DAILY DATA ──────────────────────────────────────────────────────
[c01,dp01,fl01,dy01,tb01,rd01,fm01,wt01] = request.security(sym01,"D",f_bear_htf())
[c02,dp02,fl02,dy02,tb02,rd02,fm02,wt02] = request.security(sym02,"D",f_bear_htf())
[c03,dp03,fl03,dy03,tb03,rd03,fm03,wt03] = request.security(sym03,"D",f_bear_htf())
[c04,dp04,fl04,dy04,tb04,rd04,fm04,wt04] = request.security(sym04,"D",f_bear_htf())
[c05,dp05,fl05,dy05,tb05,rd05,fm05,wt05] = request.security(sym05,"D",f_bear_htf())
[c06,dp06,fl06,dy06,tb06,rd06,fm06,wt06] = request.security(sym06,"D",f_bear_htf())
[c07,dp07,fl07,dy07,tb07,rd07,fm07,wt07] = request.security(sym07,"D",f_bear_htf())
[c08,dp08,fl08,dy08,tb08,rd08,fm08,wt08] = request.security(sym08,"D",f_bear_htf())
[c09,dp09,fl09,dy09,tb09,rd09,fm09,wt09] = request.security(sym09,"D",f_bear_htf())
[c10,dp10,fl10,dy10,tb10,rd10,fm10,wt10] = request.security(sym10,"D",f_bear_htf())
[c11,dp11,fl11,dy11,tb11,rd11,fm11,wt11] = request.security(sym11,"D",f_bear_htf())
[c12,dp12,fl12,dy12,tb12,rd12,fm12,wt12] = request.security(sym12,"D",f_bear_htf())
[c13,dp13,fl13,dy13,tb13,rd13,fm13,wt13] = request.security(sym13,"D",f_bear_htf())
[c14,dp14,fl14,dy14,tb14,rd14,fm14,wt14] = request.security(sym14,"D",f_bear_htf())
[c15,dp15,fl15,dy15,tb15,rd15,fm15,wt15] = request.security(sym15,"D",f_bear_htf())
[c16,dp16,fl16,dy16,tb16,rd16,fm16,wt16] = request.security(sym16,"D",f_bear_htf())
[c17,dp17,fl17,dy17,tb17,rd17,fm17,wt17] = request.security(sym17,"D",f_bear_htf())
[c18,dp18,fl18,dy18,tb18,rd18,fm18,wt18] = request.security(sym18,"D",f_bear_htf())
[c19,dp19,fl19,dy19,tb19,rd19,fm19,wt19] = request.security(sym19,"D",f_bear_htf())
[c20,dp20,fl20,dy20,tb20,rd20,fm20,wt20] = request.security(sym20,"D",f_bear_htf())

// ─── HELPERS ───────────────────────────────────────────────────────────────
f_ticker(sym) =>
    parts = str.split(sym, ":")
    array.size(parts) > 1 ? array.get(parts, 1) : sym

f_price_fmt(p) =>
    p >= 1000 ? str.tostring(p, "#,###.0") : p >= 1 ? str.tostring(p, "#.##") : str.tostring(p, "#.####")

f_row_bg(rd, fm) =>
    rd ? color.new(color.red, 72) : fm ? color.new(color.orange, 82) : color.new(color.black, 45)

f_status_txt(rd, fm, wt) =>
    rd ? "🔴 SHORT READY" : fm ? "🔻 FORMING" : wt ? "👀 WATCHING" : "—  no setup"

f_status_bg(rd, fm, wt) =>
    rd ? color.new(color.red, 5) : fm ? color.new(color.orange, 15) : wt ? color.new(color.yellow, 25) : color.new(color.gray, 65)

f_status_tc(rd, fm, wt) =>
    rd ? color.white : fm ? color.black : wt ? color.black : color.new(color.gray, 15)

// ─── TABLE ─────────────────────────────────────────────────────────────────
var table t = table.new(position.top_left, 7, 24,
     bgcolor=color.new(color.black, 15),
     border_width=1, border_color=color.new(color.gray, 55),
     frame_width=2,  frame_color=color.new(color.gray, 35))

if barstate.islast
    // ── REGIME HEADER (rows 0-1) ──
    regime_txt   = regime_bear ? "🐻 BEAR MARKET" : regime_trans ? "⚠️ TRANSITION" : "🐂 BULL MARKET"
    regime_bg    = regime_bear ? color.new(color.red, 15) : regime_trans ? color.new(color.orange, 20) : color.new(color.green, 20)
    regime_tc    = color.white
    bias_txt     = regime_bear ? "BIAS: SHORT ▼" : regime_trans ? "BIAS: NEUTRAL" : "BIAS: LONG ▲"
    bias_bg      = regime_bear ? color.new(color.red, 30) : regime_trans ? color.new(color.orange, 30) : color.new(color.green, 30)
    score_txt    = "Score: " + str.tostring(bear_score) + "/10"
    btc_vs_txt   = btc_w_close > btc_ema200_w ? "BTC > EMA200W ✓" : "BTC < EMA200W ✗"
    dd_txt       = "DD: -" + str.tostring(btc_dd, "#.0") + "% ATH"
    rsi_txt      = "RSI: " + str.tostring(btc_rsi_w, "#.0")

    table.cell(t, 0, 0, "🌍 MARKET REGIME", text_color=regime_tc, bgcolor=regime_bg, text_size=size.small, text_halign=text.align_left)
    table.cell(t, 1, 0, regime_txt,          text_color=regime_tc, bgcolor=regime_bg, text_size=size.small, text_halign=text.align_center)
    table.cell(t, 2, 0, bias_txt,            text_color=regime_tc, bgcolor=bias_bg,   text_size=size.small, text_halign=text.align_center)
    table.cell(t, 3, 0, score_txt,           text_color=regime_tc, bgcolor=regime_bg, text_size=size.small, text_halign=text.align_center)
    table.cell(t, 4, 0, btc_vs_txt,          text_color=regime_tc, bgcolor=regime_bg, text_size=size.small, text_halign=text.align_center)
    table.cell(t, 5, 0, dd_txt,              text_color=regime_tc, bgcolor=regime_bg, text_size=size.small, text_halign=text.align_center)
    table.cell(t, 6, 0, rsi_txt,             text_color=regime_tc, bgcolor=regime_bg, text_size=size.small, text_halign=text.align_center)

    // ── COLUMN HEADERS (row 1) ──
    hbg = color.new(#3e0000, 0)
    htc = color.white
    table.cell(t, 0, 1, "ASSET",        text_color=htc, bgcolor=hbg, text_size=size.small, text_halign=text.align_center)
    table.cell(t, 1, 1, "PRICE",        text_color=htc, bgcolor=hbg, text_size=size.small, text_halign=text.align_center)
    table.cell(t, 2, 1, "PRIOR DROP",   text_color=htc, bgcolor=hbg, text_size=size.small, text_halign=text.align_center)
    table.cell(t, 3, 1, "BOUNCE RANGE", text_color=htc, bgcolor=hbg, text_size=size.small, text_halign=text.align_center)
    table.cell(t, 4, 1, "VOL DRY-UP",   text_color=htc, bgcolor=hbg, text_size=size.small, text_halign=text.align_center)
    table.cell(t, 5, 1, "TO BREAK",     text_color=htc, bgcolor=hbg, text_size=size.small, text_halign=text.align_center)
    table.cell(t, 6, 1, "STATUS",       text_color=htc, bgcolor=hbg, text_size=size.small, text_halign=text.align_center)

    // ── DATA ROWS (2-21) ──
    tc = color.new(color.white, 5)
    bg = f_row_bg(rd01,fm01)
    table.cell(t,0,2,f_ticker(sym01),text_color=tc,bgcolor=bg,text_size=size.small)
    table.cell(t,1,2,f_price_fmt(c01),text_color=tc,bgcolor=bg,text_size=size.small)
    table.cell(t,2,2,"-"+str.tostring(dp01,"#.0")+"%",text_color=dp01>=drop_min_pct?color.new(color.red,10):color.new(color.gray,25),bgcolor=bg,text_size=size.small)
    table.cell(t,3,2,str.tostring(fl01,"#.0")+"%",text_color=fl01<=flag_max_pct?color.new(#00e676,0):color.new(color.orange,10),bgcolor=bg,text_size=size.small)
    table.cell(t,4,2,dy01?"✓ DRY":"✗ WET",text_color=dy01?color.new(#00e676,0):color.new(color.orange,10),bgcolor=bg,text_size=size.small)
    table.cell(t,5,2,tb01<999?str.tostring(tb01,"#.1")+"%":"far",text_color=tc,bgcolor=bg,text_size=size.small)
    table.cell(t,6,2,f_status_txt(rd01,fm01,wt01),text_color=f_status_tc(rd01,fm01,wt01),bgcolor=f_status_bg(rd01,fm01,wt01),text_size=size.small)
    bg:=f_row_bg(rd02,fm02)
    table.cell(t,0,3,f_ticker(sym02),text_color=tc,bgcolor=bg,text_size=size.small)
    table.cell(t,1,3,f_price_fmt(c02),text_color=tc,bgcolor=bg,text_size=size.small)
    table.cell(t,2,3,"-"+str.tostring(dp02,"#.0")+"%",text_color=dp02>=drop_min_pct?color.new(color.red,10):color.new(color.gray,25),bgcolor=bg,text_size=size.small)
    table.cell(t,3,3,str.tostring(fl02,"#.0")+"%",text_color=fl02<=flag_max_pct?color.new(#00e676,0):color.new(color.orange,10),bgcolor=bg,text_size=size.small)
    table.cell(t,4,3,dy02?"✓ DRY":"✗ WET",text_color=dy02?color.new(#00e676,0):color.new(color.orange,10),bgcolor=bg,text_size=size.small)
    table.cell(t,5,3,tb02<999?str.tostring(tb02,"#.1")+"%":"far",text_color=tc,bgcolor=bg,text_size=size.small)
