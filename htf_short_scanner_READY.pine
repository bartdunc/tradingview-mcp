    bg:=f_row_bg(rd08,fm08)
    table.cell(t,0,9,f_ticker(sym08),text_color=tc,bgcolor=bg,text_size=size.small)
    table.cell(t,1,9,f_price_fmt(c08),text_color=tc,bgcolor=bg,text_size=size.small)
    table.cell(t,2,9,"-"+str.tostring(dp08,"#.0")+"%",text_color=dp08>=drop_min_pct?color.new(color.red,10):color.new(color.gray,25),bgcolor=bg,text_size=size.small)
    table.cell(t,3,9,str.tostring(fl08,"#.0")+"%",text_color=fl08<=flag_max_pct?color.new(#00e676,0):color.new(color.orange,10),bgcolor=bg,text_size=size.small)
