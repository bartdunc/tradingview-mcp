    if not regime_bear
        warn_txt = regime_trans ? "⚠️  TRANSITION — short setups carry higher risk" : "🐂  BULL MARKET — shorting is counter-trend, reduce size"
        warn_bg  = regime_trans ? color.new(color.orange, 30) : color.new(color.green, 30)
        table.cell(t,0,23,warn_txt,text_color=color.white,bgcolor=warn_bg,text_size=size.tiny)
        table.cell(t,1,23,"",bgcolor=warn_bg)
        table.cell(t,2,23,"",bgcolor=warn_bg)
        table.cell(t,3,23,"",bgcolor=warn_bg)
        table.cell(t,4,23,"",bgcolor=warn_bg)
