    n_forming = (fm01?1:0)+(fm02?1:0)+(fm03?1:0)+(fm04?1:0)+(fm05?1:0)+(fm06?1:0)+(fm07?1:0)+(fm08?1:0)+(fm09?1:0)+(fm10?1:0)+(fm11?1:0)+(fm12?1:0)+(fm13?1:0)+(fm14?1:0)+(fm15?1:0)+(fm16?1:0)+(fm17?1:0)+(fm18?1:0)+(fm19?1:0)+(fm20?1:0)
    footer    = "🔴 " + str.tostring(n_ready) + " SHORT READY   ·   🔻 " + str.tostring(n_forming) + " FORMING   ·   Bear Flag Scanner [TraderXO]"
