    table.cell(t,5,9,tb08<999?str.tostring(tb08,"#.1")+"%":"far",text_color=tc,bgcolor=bg,text_size=size.small)
    table.cell(t,6,9,f_status_txt(rd08,fm08,wt08),text_color=f_status_tc(rd08,fm08,wt08),bgcolor=f_status_bg(rd08,fm08,wt08),text_size=size.small)
    bg:=f_row_bg(rd09,fm09)
