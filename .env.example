# Copy this file to .env and fill in your values
# .env is git-ignored — never commit real keys

# ── Solana auto-trade bot ─────────────────────────────────────────────────────
# Private key of the wallet the bot trades from.
# Formats accepted:
#   base58  — the standard format shown by Phantom / Solflare export
#   JSON    — array of 64 numbers, e.g. [1,2,3,...]  (Solana CLI format)
#
# ⚠  Use a DEDICATED bot wallet — never your main wallet.
# ⚠  Fund it with only as much SOL as you're willing to lose entirely.
SOLANA_PRIVATE_KEY=

# Optional: custom RPC endpoint (Helius RPC is faster than public mainnet)
# If left blank, the Helius API key in sniper.json is used automatically.
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
